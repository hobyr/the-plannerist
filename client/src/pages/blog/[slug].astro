---
import { StrapiBlocks } from '@sensinum/astro-strapi-blocks';
import Layout from '../../layouts/Layout.astro';
import fetchApi from '../../lib/strapi';
import { Image } from 'astro:assets';

export async function getStaticPaths() {
  const articles = await fetchApi({
    endpoint: 'blogs',
    wrappedByKey: 'data',
    query: {
      'populate[0]': 'cover',
      'populate[1]': 'call_to_action',
      'populate[2]': 'author',
    }
  });

  return articles.map((article) => ({
    params: { slug: article.slug },
    props: article,
  }));
};


const article = Astro.props;
const optionsDate = {
year: "numeric",
month: "long",
day: "numeric"
};
const locale = 'fr-FR';
let FormattedDate = null;
if (article.posted_at) {
FormattedDate = Intl.DateTimeFormat(locale, optionsDate).format(new Date(article.posted_at));
} else {
FormattedDate = Intl.DateTimeFormat(locale, optionsDate).format(new Date(article.publishedAt));
}

// Calculate estimated reading time
const readingSpeedWPM = 170;
let wordCount = 0;
article.content.map(ctx => {
if (ctx.children[0].text) {
  wordCount += ctx.children[0].text.trim().split(/\s+/).length;
  }
})
const readingTime = Math.round(wordCount/readingSpeedWPM);

// Create table of contents with 1 level deep headings
let toc = [];
toc.push(article.title);
for (let item of article.content) {
  if (item.type === "heading") {
    if (item.level === 2) {
    toc.push(item.children[0].text);
    }
  }
}
---

<Layout>
  <!-- <div class="bg-blob blob-1"></div> -->
  <!-- <div class="bg-blob blob-2"></div> -->
  <!-- <div class="bg-blob blob-3"></div> -->
  <!-- <div class="bg-blob blob-4"></div> -->
  <!-- <div class="bg-blob blob-5"></div> -->
  <Image src={article.cover.url} width={1400} height={400} alt="" class="post-cover" />
  <div class="post-cover-copyright">Copyright couverture: photographe</div>
  <section id="post">
    <div class="container">
      <header>
        <h1 class="page-title">{article.title}</h1>
        <div class="info">
          <span class="posting-date">Écrit par {article.author.name}</span>
          <span class="posting-date">Publié le {FormattedDate}</span>
          <span class="reading-time">Temps de lecture estimé : {readingTime} minutes</span>
        </div>
      </header>
      <div class="article">
        <div class="table-of-contents">
          <h2>Sommaire</h2>
          {toc.map(heading => <div>{heading}</div>)}
        </div>
        <article>
          <StrapiBlocks
              data={article.content}
              />
              <a href={article.call_to_action.cta_url} target="_blank" rel="noopener noreferrer" class="button cta">{article.call_to_action.cta_label}</a>
        </article>
      </div>
    </div>
  </section>
</Layout>

<style>
  :root {
    --blob-col-1: #F4E04D;
    --blob-col-2: #95BF74;
    --blob-col-3: #DDA77B;
    /* --blob-col-3: #669BBC; */
  }

  .bg-blob {
    position: absolute;
    --length: 600px;
    width: var(--length);
    height: var(--length);
    z-index: -1;
    filter: blur(500px);
  }

  .blob-1 {
    top: 0;
    right: 0;
    background-color: var(--blob-col-1);
  }

  .blob-2 {
    left: 0;
    top: 800px;
    background-color: var(--blob-col-2);
  }

  .blob-3 {
    top: 1400px;
    right: 0;
    background-color: var(--blob-col-3);
  }

  .blob-4 {
    top: 2400px;
    left: 0;
    background-color: var(--blob-col-1);
  }

  .blob-5 {
    top: 3800px;
    right: 0px;
    background-color: var(--bg-color-dark);
  }

  header {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-block: 2rem;
  }

  header .info span + span {
    margin-left: var(--space-s);
    padding-left: var(--space-s);
    border-left: 2px solid #bababa;
  }

  .page-title {
    margin-bottom: 1rem;
  }

  .article {
    display: grid;
    grid-template-columns: 1fr 70ch;
    column-gap: var(--space-xl);
    position: relative;
    margin-top: 2rem;
  }

  .table-of-contents {
    position: sticky;
    top: 100px;
    height: fit-content;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .post-cover {
    width: 100%;
    height: 60vh;
    max-height: 600px;
    object-fit: cover;
  }

  .post-cover-copyright {
    margin-left: var(--space-m);
  }

  .post-cover-copyright,
  .reading-time,
  .posting-date {
    color: #808080;
    text-align: center;
  }

  article {
    max-width: 70ch;
    margin: 0 auto;
    padding-left: var(--space-xl);
    border-left: 1px solid var(--bg-color-light);
  }
</style>
