---
import Layout from '../../layouts/Layout.astro';
import fetchApi from '../../lib/strapi.ts';
import { Image } from 'astro:assets';

// SSR
export const prerender = false;

const currentPageNumber = !Astro.url.searchParams.get("page") ? 1 : Number(Astro.url.searchParams.get("page"));
const pageSize = 9;

const data = await fetchApi({
endpoint: 'blogs',
query: {
'populate': 'cover',
'pagination[page]': currentPageNumber,
'pagination[pageSize]': pageSize,
}
});

const articles = data.data;
const lastPage = data.meta.pagination.pageCount;

// Fix URL path for local development
for (let article of articles) {
if (import.meta.env.NODE_ENV === 'development') {
  article.CoverURL = import.meta.env.STRAPI_URL + article.cover.url;
}
}

const topArticles = articles.slice(0,6);
const remainArticles = articles.slice(6);
---

<Layout>
  <section id="posts">
    <div class="container">
      <div class="title-header">Mieux piloter &amp; décider</div>
      <h1 class="page-title">Le carnet de bord stratégique de The Plannerist</h1>
      <div class="post-grid">
        {topArticles.map(article => 
        <div class="article-card">
          <Image src={article.CoverURL ? article.CoverURL : article.cover.url} alt="" width={3000} height={3000} class="card-cover"/>
          <div class="card-content">
            <h3>{article.title}</h3>
            <div class="article-date">{Intl.DateTimeFormat("fr-FR", { year: "numeric", month: "long", day: "numeric" }).format(article.posted_at ? new Date(article.posted_at) : new Date(2026,3,15))}</div>
            <a href={`/blog/${article.slug}`} class="card-cta">Voir l'article <span><i class="fa-solid fa-arrow-right"></i></span></a>
          </div>
        </div>
        )}
      </div>
      <h2 class="section-title">Autres articles</h2>
      <div class="article-grid-2">
        {remainArticles.map(article => 
        <div class="article-card">
          <Image src={article.CoverURL ? article.CoverURL : article.cover.url} alt="" width={3000} height={3000} class="card-cover"/>
          <div class="card-content">
            <h3>{article.title}</h3>
            <div class="article-date">{Intl.DateTimeFormat("fr-FR", { year: "numeric", month: "long", day: "numeric" }).format(article.posted_at ? new Date(article.posted_at) : new Date(2026,3,15))}</div>
            <a href={`/blog/${article.slug}`} class="card-cta">Voir l'article <span><i class="fa-solid fa-arrow-right"></i></span></a>
          </div>
        </div>
        )}
      </div>
      <nav class="pagination">
        <!-- First page link -->
        {currentPageNumber > 1 ? <a href="/blog">1</a> : null}
        <!-- Previous page link -->
        {currentPageNumber > 2 ? <a href=`/blog?page=${currentPageNumber - 1}`>{currentPageNumber - 1}</a> : null}
        <!-- Current page link -->
        <div>{currentPageNumber}</div>
        <!-- Next page link -->
        {currentPageNumber < lastPage - 1 ? <a href=`/blog?page=${currentPageNumber + 1}`>{currentPageNumber + 1}</a> : null}
        <!-- Last page link -->
        {currentPageNumber < lastPage ? <a href=`/blog?page=${lastPage}`>{lastPage}</a> : null}
      </nav>
    </div>
  </section>
</Layout>

<style>
  .container {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .post-grid {
    width: 100%;
    display: grid;
    gap: var(--space-l);
    grid-template-columns: repeat(6, 1fr);
    grid-template-rows: auto;
    grid-template-areas:
      "hero hero hero hero aside2 aside2"
      "hero hero hero hero aside2 aside2"
      "hero hero hero hero aside3 aside3"
      "hero hero hero hero aside3 aside3"
      "aside4 aside4 aside5 aside5 aside6 aside6"
      "aside4 aside4 aside5 aside5 aside6 aside6";
    margin-bottom: var(--space-m);
  }

  .post-grid .article-card:nth-child(1) {
    grid-area: hero;
  }

  .post-grid .article-card:nth-child(2) {
    grid-area: aside2;
  }

  .post-grid .article-card:nth-child(3) {
    grid-area: aside3;
  }

  .post-grid .article-card:nth-child(4) {
    grid-area: aside4;
  }

  .post-grid .article-card:nth-child(5) {
    grid-area: aside5;
  }

  .post-grid .article-card:nth-child(6) {
    grid-area: aside6;
  }

  .article-card {
    min-height: 15rem;
    width: 100%;
    display: flex;
    flex-direction: column;
  }

  .article-grid-2 {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(25rem, 1fr));
    gap: var(--space-l);
    margin-top: var(--space-m);
  }

  .article-card .card-cover {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .article-card .card-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-m);
    padding: var(--space-s);
    padding-left: 0;
  }

  .article-card h3 {
    font-size: var(--step-1);
    margin-top: 0;
    margin-bottom: 0;
  }

  .article-date {
    font-size: var(--step-0);
    font-weight: 200;
    color: #808080;
  }

  a.card-cta {
    display: flex;
    gap: var(--space-2xs);
    align-items: flex-end;
    text-decoration: none;
    color: var(--text);
    border-bottom: 1px solid var(--text);
    width: fit-content;

    transition-property: gap, color, border-color;
  }

  a.card-cta span {
    font-size: var(--step--1);
  }

  a.card-cta:hover {
    color: var(--bg-color-light);
    gap: var(--space-xs);
    border-color: var(--bg-color-light);
  } 
</style>
