---
import Layout from '../../layouts/Layout.astro';
import fetchApi from '../../lib/strapi.ts';
import { Image } from 'astro:assets';

const articles = await fetchApi({
endpoint: 'blogs',
wrappedByKey: 'data',
query: {
'populate': 'cover',
'pagination[offset]': '0',
'pagination[limit]': '5',
}
});
// console.log(articles);
---

<Layout>
  <!-- <div class="bg-blob blob-1"></div> -->
  <!-- <div class="bg-blob blob-2"></div> -->
  <!-- <div class="bg-blob blob-3"></div> -->
  <!-- <div class="bg-blob blob-4"></div> -->
  <!-- <div class="bg-blob blob-5"></div> -->
  <section id="posts">
    <div class="container">
      <div class="title-header">Mieux piloter &amp; décider</div>
      <h1 class="page-title">Le carnet de bord stratégique de The Plannerist</h1>
      <div class="article-grid">
        {articles.map(article => 
        <div class="article-card">
          <Image src=`${import.meta.env.STRAPI_URL}${article.cover.url}` alt="" width={300} height={250} class="card-cover"/>
          <div class="card-content">
            <h3>{article.title}</h3>
            <p>{article.description}</p>
            <a href={`/blog/${article.slug}`} class="card-cta">Voir l'article <span><i class="fa-solid fa-arrow-right"></i></span></a>
          </div>
        </div>
        )}
      </div>
    </div>
  </section>
</Layout>

<style>
  :root {
    --blob-col-1: #F4E04D;
    --blob-col-2: #95BF74;
    --blob-col-3: #DDA77B;
    /* --blob-col-3: #669BBC; */
  }

  .bg-blob {
    position: absolute;
    --length: 600px;
    width: var(--length);
    height: var(--length);
    z-index: -1;
    filter: blur(500px);
  }

  .blob-1 {
    top: 0;
    right: 0;
    background-color: var(--blob-col-1);
  }

  .blob-2 {
    left: 0;
    top: 800px;
    background-color: var(--blob-col-2);
  }

  .blob-3 {
    top: 1400px;
    right: 0;
    background-color: var(--blob-col-3);
  }

  .blob-4 {
    top: 2400px;
    left: 0;
    background-color: var(--blob-col-1);
  }

  .blob-5 {
    top: 3800px;
    right: 0px;
    background-color: var(--bg-color-dark);
  }

  .container {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .article-grid {
    width: 100%;
    display: grid;
    gap: var(--space-l);
    grid-template-columns: repeat(6, 1fr);
    grid-template-rows: auto;
    grid-template-areas:
      "hero hero hero hero aside2 aside2"
      "hero hero hero hero aside2 aside2"
      "hero hero hero hero aside3 aside3"
      "hero hero hero hero aside3 aside3"
      "aside4 aside4 aside4 aside5 aside5 aside5";
  }

  .article-card:nth-child(1) {
    grid-area: hero;
  }

  .article-card:nth-child(2) {
    grid-area: aside2;
  }

  .article-card:nth-child(3) {
    grid-area: aside3;
  }

  .article-card:nth-child(4) {
    grid-area: aside4;
  }

  .article-card:nth-child(5) {
    grid-area: aside5;
  }

  .article-card {
    min-height: 15rem;
    width: 100%;
    /* border: 1px solid red; */
    display: flex;
    flex-direction: column;
  }

  .article-card .card-cover {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .article-card .card-content {
    flex: 1;
    min-height: 15rem;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    padding: var(--space-s);
    padding-left: 0;
  }

  .article-card h3 {
    font-size: var(--step-0);
    margin-top: 0;
    margin-bottom: 0;
  }

  .card-content p {
    margin-top: .5rem;;
    font-size: var(--step-0);
    margin-bottom: auto;
  }

  a.card-cta {
    display: flex;
    gap: var(--space-2xs);
    align-items: flex-end;
    text-decoration: none;
    color: var(--text);
    border-bottom: 1px solid var(--text);
    width: fit-content;

    transition-property: gap, color, border-color;
  }

  a.card-cta span {
    font-size: var(--step--1);
  }

  a.card-cta:hover {
    color: var(--bg-color-light);
    gap: var(--space-xs);
    border-color: var(--bg-color-light);
  } 
</style>
