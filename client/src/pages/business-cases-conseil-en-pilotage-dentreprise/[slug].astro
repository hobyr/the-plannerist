---
import { StrapiBlocks } from '@sensinum/astro-strapi-blocks';
import Layout from '../../layouts/Layout.astro';
import fetchApi from '../../lib/strapi';
import { Image } from 'astro:assets';

export async function getStaticPaths() {
  const cases = await fetchApi({
    endpoint: 'business-cases',
    wrappedByKey: 'data',
    query: {
      'populate': '*',
    }
    });

    return cases.map((business_case) => ({
      params: { slug: business_case.slug},
      props: business_case,
    }))
    }

    const business_case = Astro.props
---

<Layout>
  <section class="business-case">
    <div class="container">

    </div>
  </section>
</Layout>

<style>
  :root {
    --blob-col-1: #F4E04D;
    --blob-col-2: #95BF74;
    --blob-col-3: #DDA77B;
    /* --blob-col-3: #669BBC; */
  }

  .bg-blob {
    position: absolute;
    --length: 600px;
    width: var(--length);
    height: var(--length);
    z-index: -1;
    filter: blur(500px);
  }

  .blob-1 {
    top: 0;
    right: 0;
    background-color: var(--blob-col-1);
  }

  .blob-2 {
    left: 0;
    top: 800px;
    background-color: var(--blob-col-2);
  }

  .blob-3 {
    top: 1400px;
    right: 0;
    background-color: var(--blob-col-3);
  }

  .blob-4 {
    top: 2400px;
    left: 0;
    background-color: var(--blob-col-1);
  }

  .blob-5 {
    top: 3800px;
    right: 0px;
    background-color: var(--bg-color-dark);
  }

  header {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-block: 2rem;
  }

  header .info span + span {
    margin-left: var(--space-s);
    padding-left: var(--space-s);
    border-left: 2px solid #bababa;
  }

  .page-title {
    margin-bottom: 1rem;
  }

  .article {
    display: grid;
    grid-template-columns: 1fr 70ch;
    column-gap: var(--space-xl);
    position: relative;
    margin-top: 2rem;
  }

  .table-of-contents {
    position: sticky;
    top: 100px;
    height: fit-content;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .post-cover {
    width: 100%;
    height: 60vh;
    max-height: 600px;
    object-fit: cover;
  }

  .post-cover-copyright {
    margin-left: var(--space-m);
  }

  .post-cover-copyright,
  .reading-time,
  .posting-date {
    color: #808080;
    text-align: center;
  }

  article {
    max-width: 70ch;
    margin: 0 auto;
    padding-left: var(--space-xl);
    border-left: 1px solid var(--bg-color-light);
  }
</style>
