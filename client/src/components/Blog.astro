---
import '../styles/global.css';
---
<section id="blog">
  <div class="container">
    <h2 class="section-title">Les derniers articles de blog</h2>
  </div>
</section>

<style>
  .container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-l);
  }

  h2 span {
    font-style: italic;
  }

  .buttons {
    display: flex;
    flex-direction: row;
    justify-content: center;
    gap: var(--space-s);
  }
</style>

