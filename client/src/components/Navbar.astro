---
import '../styles/global.css';
import { links } from './links.js'
import { Image } from 'astro:assets';
import logo from '../assets/logos/logo-dark.png';
const currentPath = Astro.url.pathname;
---

<header class="top-navbar-wrapper">
  <div class="container top-navbar">
    <Image src={logo} height={40} alt="" />
    <nav>
      {links.map(link => <a href={link.url} class={`nav-link${currentPath === link.url ? ' active' : ''}`}>{link.name}</a>)}
      <a href="" class="button cta"><span><i class="fa-solid fa-file-arrow-down"></i></span> +30 process à mettre en place</a>
    </nav>
  </div>
<script>
  window.onscroll = () => {
    let navbar = document.querySelector(".top-navbar-wrapper");
    if(document.documentElement.scrollTop > 80) {
      navbar.classList.add("after-scroll");
    } else {
      navbar.classList.remove("after-scroll");
    }
  }
</script>
  </header>

<style>
  .top-navbar-wrapper {
    position: sticky;
    top: 0;
    margin: 0 auto;
    padding: 1rem 0;
    border-radius: 999px;
    z-index: 10;
    width: min(97%, 1500px);

    transition-property: padding, background-image, top, box-shadow;
    transition-duration: 300ms;
    transition-timing-function: ease;
  }

  .after-scroll {
    top: 14px;
    background-image: linear-gradient(0deg, #ffffffc3 0%, #ffffff93 100%);
    box-shadow: 0px 4px 8px #33333380;
    backdrop-filter: blur(6px);
  }

  .top-navbar {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
  }

  nav {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
  }

  .nav-link {
    color: var(--bg-color-dark);
    text-decoration: none;
    text-transform: uppercase;
    font-weight: 400;
    font-size: var(--step--1);
    position: relative;
    width: fit-content;
    z-index: 1;
  }

  .nav-link.active {
    border-bottom: 2px solid var(--text);
  }

  .nav-link:hover {
    color: var(--primary);
    background-color: var(--primary-xtra-light);
  }

  .cta {
    color: white;
    background-color: var(--text);
    border: 2px solid var(--text);
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: flex-start;
    gap: var(--space-2xs);
    width: fit-content;
    padding: .25rem .75rem .25rem .25rem;
  }

  .cta:hover {
    background-color: var(--primary-light);
    color: var(--primary);
    border-color: var(--primary);
  }

  .cta i {
    width: 2rem;
    aspect-ratio: 1/1;
    border-radius: 999px;
    display: flex;
    justify-content: center;
    align-items: center;
    background-color: white;
    color: var(--text);

    transition-property: background-color, color;
    transition-duration: 150ms;
    transition-timing-function: ease-in;
  }

  .cta:hover i {
    color: var(--primary-light);
    background-color: var(--primary);
  }
</style>

