---
import '../styles/global.css';
import { links } from './links.js'
import { Image } from 'astro:assets';
import logo from '../assets/logos/logo-dark.png';

// const { currentPath } = Astro.props;
const currentPath = Astro.url.pathname;
console.log(currentPath);
---

<header class="top-navbar-wrapper">
  <div class="container top-navbar">
    <Image src={logo} width={300} alt="" class="top-logo" />
    <nav>
      <header>
        <Image src={logo} width={300} height={140} alt="" class="mobile-logo"/>
        <div class="toggle-button"><span><i class="fa-solid fa-xmark"></i></span></div>
      </header>
      {links.map(link => <a href={link.url} class={`nav-link${currentPath === link.url ? ' active' : ''}`}>{link.name}</a>)}
      <a href="" class="button cta"><span><i class="fa-solid fa-file-arrow-down"></i></span> +30 process à mettre en place</a>
    </nav>
    <div class="toggle-button-main"><span><i class="fa-solid fa-bars"></i></span></div>
  </div>

<script>
  window.onscroll = () => {
    let navbar = document.querySelector(".top-navbar-wrapper");
    if(document.documentElement.scrollTop > 80) {
      navbar.classList.add("after-scroll");
    } else {
      navbar.classList.remove("after-scroll");
    }
  }

  const toggleBtnMain = document.querySelector(".top-navbar .toggle-button-main");
  const toggleBtn = document.querySelector(".top-navbar .toggle-button");
  const navbar = document.querySelector(".top-navbar nav");
  toggleBtnMain.addEventListener('click', () => {
    navbar.classList.add("active");
    document.querySelector("body").style.overflowY = "hidden";
  })
  toggleBtn?.addEventListener('click', () => {
    navbar.classList.remove("active");
    document.querySelector("body").style.overflowY = "visible";
  })
</script>
  </header>

<style>
  .top-navbar-wrapper {
    position: sticky;
    top: 0;
    margin: 0 auto;
    border-radius: 999px;
    z-index: 10;
    width: min(97%, 1500px);

    transition-property: padding, background-image, top, box-shadow;
    transition-duration: 300ms;
    transition-timing-function: ease;
  }

  .top-navbar {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    padding: 1rem;
  }

  .top-logo {
    object-fit: contain;
    width: 180px;
    height: 40px;
  }

  nav {
    visibility: hidden;
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-m);
    padding: var(--space-m);
    height: 100vh;
    background-color: white;
  }

  nav.active {
    visibility: visible;
  }

  nav header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: var(--space-m);
    margin-bottom: var(--space-m);
    border-bottom: 1px solid black;
    width: 100%;
  }

  .mobile-logo {
    width: 50%;
    height: 55px;
    object-fit: contain;
  }

  .after-scroll {
    top: 14px;
    background-image: linear-gradient(0deg, #ffffffc3 0%, #ffffff93 100%);
    box-shadow: 0px 4px 8px #33333380;
    backdrop-filter: blur(6px);
  }

  .nav-link {
    color: var(--bg-color-dark);
    text-decoration: none;
    text-transform: uppercase;
    font-weight: 400;
    font-size: var(--step--1);
    position: relative;
    width: fit-content;
    z-index: 1;
  }

  .nav-link.active {
    border-bottom: 2px solid var(--text);
  }

  .nav-link:hover {
    color: var(--bg-color-light);
  }

  .cta {
    color: white;
    background-color: var(--text);
    border: 2px solid var(--text);
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: flex-start;
    gap: var(--space-2xs);
    width: fit-content;
    padding: .25rem .75rem .25rem .25rem;
  }

  .cta:hover {
    background-color: var(--primary-light);
    color: var(--primary);
    border-color: var(--primary);
  }

  .cta i {
    width: 2rem;
    aspect-ratio: 1/1;
    border-radius: 999px;
    display: flex;
    justify-content: center;
    align-items: center;
    background-color: white;
    color: var(--text);

    transition-property: background-color, color;
    transition-duration: 150ms;
    transition-timing-function: ease-in;
  }

  .cta:hover i {
    color: var(--primary-light);
    background-color: var(--primary);
  }

  @media (min-width: 1000px) {
    .top-navbar {
      padding: 1rem 0;
    }

    nav {
      visibility: visible;
      position: relative;
      width: fit-content;
      flex-direction: row;
      align-items: center;
      gap: var(--space-xs);
      height: 100%;
      padding: 0;
      background-color: transparent;
    }

    nav header,
    .toggle-button-main {
      display: none;
    }
  }
</style>

