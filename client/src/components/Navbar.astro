---
import '../styles/global.css';
import { links } from './links.js'
import { Image } from 'astro:assets';
import logo from '../assets/logos/logo-dark.png';
---

<header class="top-navbar-wrapper">
  <div class="container top-navbar">
    <Image src={logo} height={40} alt="" />
    <nav>
      {links.map(link => <a href={link.url}>{link.name}</a>)}
      <a href="" class="button cta">+30 process à mettre en place</a>
    </nav>
  </div>
<script>
  window.onscroll = () => {
    let navbar = document.querySelector(".top-navbar-wrapper");
    if(document.documentElement.scrollTop > 80) {
      navbar.classList.add("after-scroll");
    } else {
      navbar.classList.remove("after-scroll");
    }
  }
</script>
</header>

<style>
  .top-navbar-wrapper {
    position: sticky;
    top: 0;
    margin: 0 auto;
    padding: 1.5rem 0;
    border-radius: 999px;
    width: min(97%, 1500px);
    z-index: 10;

    transition-property: padding, background-image, top, box-shadow;
    transition-duration: 300ms;
    transition-timing-function: ease;
  }

  .after-scroll {
    top: 14px;
    background-image: linear-gradient(0deg, #ffffffc3 0%, #ffffff93 100%);
    box-shadow: 0px 4px 8px #33333380;
    backdrop-filter: blur(6px);

  }

  .top-navbar {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
  }

  nav a + a {
    margin-left: var(--space-s);
  }

  nav a {
    color: var(--bg-color-dark);
    text-decoration: none;
    text-transform: uppercase;
    font-weight: 400;
    font-size: var(--step--1);
  }

  .button.cta {
    color: white;
  }
</style>

